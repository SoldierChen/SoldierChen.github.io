<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div class="table-responsive news-scroll" tabindex="0" aria-label="News archive">
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and site.announcements.limit %}
          {% assign news_limit = site.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr>
            <th scope="row">
              {% if page.lang == 'zh' %}
                {{ item.date | date: '%Y年%m月' }}
              {% else %}
                {{ item.date | date: '%b %Y' }}
              {% endif %}
            </th>
            <td>
              {% if page.lang == 'zh' %}
                {{ item.zh | default: item.content | markdownify | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                {% if item.inline %}
                  {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                {% else %}
                  <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
                {% endif %}
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
