---
layout: default
---
{% assign content_lang = page.lang | default: 'en' %}
{% assign profile = site.data.home.profile %}
<div class="home-page-shell">
  <aside class="home-profile-card" aria-label="{% if page.lang == 'zh' %}个人资料{% else %}Profile{% endif %}">
    <img
      class="home-portrait"
      src="{{ profile.image | prepend: '/assets/img/' | relative_url }}"
      alt="{% if page.lang == 'zh' %}陈鑫宇的个人照片{% else %}Portrait of Xinyu Chen{% endif %}"
    >
    <div class="home-profile-body">
      <h1>{{ profile.name }}</h1>
      <p class="home-role">{{ profile.role[content_lang] }}</p>

      <div class="home-affiliation">
        {% for affiliation in profile.affiliations %}
          <a href="{{ affiliation.url }}" target="_blank" rel="noopener">{{ affiliation[content_lang] }}</a>
        {% endfor %}
      </div>

      <dl class="home-contact-list">
        <div>
          <dt>{% if page.lang == 'zh' %}邮箱{% else %}Email{% endif %}</dt>
          <dd><a href="mailto:{{ site.email }}">{{ site.email }}</a></dd>
        </div>
        <div>
          <dt>{% if page.lang == 'zh' %}办公室{% else %}Office{% endif %}</dt>
          <dd>{{ profile.office }}</dd>
        </div>
      </dl>

      <div class="home-profile-links">
        {% if site.scholar_userid %}
          <a href="https://scholar.google.com/citations?user={{ site.scholar_userid }}" target="_blank" rel="noopener">
            <i class="ai ai-google-scholar" aria-hidden="true"></i>
            <span>Google Scholar</span>
          </a>
        {% endif %}
        {% if site.github_username %}
          <a href="https://github.com/{{ site.github_username }}" target="_blank" rel="noopener">
            <i class="fa-brands fa-github" aria-hidden="true"></i>
            <span>GitHub</span>
          </a>
        {% endif %}
        {% if site.orcid_id %}
          <a href="https://orcid.org/{{ site.orcid_id }}" target="_blank" rel="noopener">
            <i class="ai ai-orcid" aria-hidden="true"></i>
            <span>ORCID</span>
          </a>
        {% endif %}
        {% if site.linkedin_username %}
          <a href="https://www.linkedin.com/in/{{ site.linkedin_username }}" target="_blank" rel="noopener">
            <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
            <span>LinkedIn</span>
          </a>
        {% endif %}
      </div>
    </div>
  </aside>

  <main class="home-main">
    {{ content }}
  </main>
</div>
